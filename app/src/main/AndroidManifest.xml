<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="Order App"
        android:theme="@style/Theme.OrderApp">

        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".DealersActivity" android:exported="false" />
        <activity android:name=".ProductsActivity" android:exported="false" />
        <activity android:name=".OrderActivity" android:exported="false" />
    </application>
</manifest>
